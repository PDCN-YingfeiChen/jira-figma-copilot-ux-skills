# Atlassian MCP Server 配置
# 复制本文件为 .env 并填写你的配置: cp .env.example .env

# ============ 必填 ============

# Atlassian 域名（不要加 https://）
ATLASSIAN_HOST=porschedigital.atlassian.net

# 你的 Atlassian 邮箱
ATLASSIAN_EMAIL=your-email@porsche.digital

# Atlassian API Token（https://id.atlassian.com/manage-profile/security/api-tokens）
ATLASSIAN_API_TOKEN=your-api-token-here

# ============ 可选 ============

# JIRA Board ID（不同团队不同）
JIRA_BOARD_ID_PHOENIX=7644
JIRA_BOARD_ID_CARSALES=7810
JIRA_BOARD_ID_TITAN=8243
JIRA_BOARD_ID_ROCKET=7777
JIRA_BOARD_ID_SST=7645
